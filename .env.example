# Mail delivery
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=gohypedevelopers@gmail.com
SMTP_PASS=your-16-character-gmail-app-password
SMTP_FROM_EMAIL=gohypedevelopers@gmail.com

# Team notification recipients
# The form requester receives a separate confirmation email automatically.
CONTACT_RECIPIENTS=ravindranathjha76@gmail.com

# Booking duration in minutes
BOOKING_DURATION_MINUTES=30

# Google Calendar + Google Meet
# Keep this enabled to create a fresh Google Meet link on every booking.
GOOGLE_CALENDAR_ENABLED=true
GOOGLE_CALENDAR_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CALENDAR_CLIENT_SECRET=your-google-oauth-client-secret
GOOGLE_CALENDAR_REFRESH_TOKEN=your-google-oauth-refresh-token
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_ORGANIZER_EMAIL=gohypedevelopers@gmail.com

# Optional fallback only if you want to disable Calendar booking.
# Leave empty when using Google Calendar invites.
GOOGLE_MEET_LINK=
